import pytest

from __PKG__.errors import KeyMissingError
from __PKG__.service import Service


def test_record_then_fetch_roundtrips():
    service = Service(capacity=2, namespace="ns")
    service.record("a", 1.5)
    assert service.fetch("a") == 1.5


def test_fetch_unrecorded_key_raises():
    with pytest.raises(KeyMissingError):
        Service(capacity=2, namespace="ns").fetch("absent")


def test_wiring_honours_the_configured_capacity():
    service = Service(capacity=1, namespace="ns")
    service.record("a", 1.0)
    service.record("b", 2.0)
    with pytest.raises(KeyMissingError):
        service.fetch("a")

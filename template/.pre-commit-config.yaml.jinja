{% set pkgs = packages.split(",") | map("trim") | join(" ") -%}
# Commit-event binding of the same gates CI enforces. No-git MVP: LOCAL hooks (repo: local +
# language: system) that shell out to uvx / uv run with the SPEC-pinned versions — no remote repo+rev
# (that path is the root .pre-commit-hooks.yaml, unused until this goes remote+versioned).
repos:
  - repo: local
    hooks:
      - id: ruff-gate
        name: ruff — enforced (full select)
        entry: uvx ruff@{{ ruff_version }} check {{ lint_paths }} --select {{ ruff_select }}
        language: system
        pass_filenames: false
        always_run: true

      - id: ruff-format-gate
        name: ruff — format check (advisory)
        entry: uvx ruff@{{ ruff_version }} format --check .
        language: system
        pass_filenames: false
        always_run: true
        verbose: true

      - id: vulture-gate
        name: vulture — dead code (conf>=80)
        entry: uvx vulture@{{ vulture_version }} --min-confidence 80
        language: system
        pass_filenames: false
        always_run: true
      {% if use_import_linter %}
      - id: importlinter-gate
        name: import-linter — directional layers
        entry: uvx --from import-linter lint-imports
        language: system
        pass_filenames: false
        always_run: true
      {% endif %}
      - id: arch-fitness
        name: architecture fitness (graph.py --assert)
        entry: uv run --extra devtools python -m devtools.graph --assert {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true

      - id: astgrep-gate
        name: ast-grep — module shape
        entry: uvx --from ast-grep-cli ast-grep scan -c devtools/sgconfig.yml {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true

      # Class-shape smells — advisory explorers (LCOM4 cohesion / Fowler data-clumps / namespace-state).
      # They only print a ranked report and always exit 0, so as commit hooks they surface findings
      # without ever blocking — advisory by construction, not by continue-on-error.
      - id: state-candidates
        name: class-shape — namespace-state (advisory)
        entry: uv run python -m devtools.state_candidates {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: lcom
        name: class-shape — LCOM4 cohesion (advisory)
        entry: uv run python -m devtools.lcom {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: data-clumps
        name: class-shape — data clumps (advisory)
        entry: uv run python -m devtools.data_clumps {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: magic-literals
        name: magic-literals — enforced ratchet ([tool.magic_literals] ceiling)
        entry: uv run python -m devtools.magic_literals {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
{% if enable_ml %}      - id: shape-contracts
        name: shape-contracts — array/tensor boundaries lacking a jaxtyping shape (advisory)
        entry: uv run python -m devtools.shape_contracts {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
{% endif %}      {# jscpd is ENFORCED in CI + nox (blocks over the jscpd.json threshold, the cardiac/mindscape
         majority) but kept OFF the commit hook — it needs Node and is slower than the static gates. A
         repo that wants it at commit time too adds a jscpd hook here. #}

{% set pkgs = packages.split(",") | map("trim") | join(" ") -%}
# Commit-event binding of the same gates CI enforces. No-git MVP: LOCAL hooks (repo: local +
# language: system) that shell out to uvx / uv run with the SPEC-pinned versions — no remote repo+rev
# (that path is the root .pre-commit-hooks.yaml, unused until this goes remote+versioned).
repos:
  - repo: local
    hooks:
      - id: ruff-gate
        name: ruff — enforced (full select)
        entry: uvx ruff@{{ ruff_version }} check {{ lint_paths }} --select {{ ruff_select }}{% if enable_ml %} --ignore F722,F821{% endif %}
        language: system
        pass_filenames: false
        always_run: true

      - id: ruff-format-gate
        name: ruff — format check (advisory)
        entry: uvx ruff@{{ ruff_version }} format --check .
        language: system
        pass_filenames: false
        always_run: true
        verbose: true

      - id: pyrefly-gate
        name: pyrefly — types (strict, enforced)
        # env-aware (`uv run --with`) so pyrefly reads installed dep stubs; scope = lint_paths (packages).
        entry: uv run --with pyrefly=={{ pyrefly_version }} pyrefly check {{ lint_paths }}
        language: system
        pass_filenames: false
        always_run: true

      - id: vulture-gate
        name: vulture — dead code (conf>=80)
        entry: uvx vulture@{{ vulture_version }} --min-confidence 80
        language: system
        pass_filenames: false
        always_run: true
      {% if use_import_linter %}
      - id: importlinter-gate
        name: import-linter — directional layers
        entry: uvx --from import-linter lint-imports
        language: system
        pass_filenames: false
        always_run: true
      {% endif %}
      - id: arch-fitness
        name: architecture fitness (graph.py --assert)
        entry: uv run --extra devtools python -m devtools.graph --assert {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true

      - id: astgrep-gate
        name: ast-grep — module shape
        # NO SHELL. The config lives in the INSTALLED devtools package, and locating it used to need
        # `bash -c` for a `$(python -m devtools.config sgconfig)` substitution — which meant this gate did
        # not run on Windows at all, where the bash pre-commit picks cannot find uv. `devtools.astgrep`
        # does that lookup in Python and runs the scan itself, so the hook is a plain entry like every other.
        entry: uv run --extra devtools python -m devtools.astgrep {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true

      # Class-shape smells — advisory explorers (LCOM4 cohesion / Fowler data-clumps / namespace-state).
      # They only print a ranked report and always exit 0, so as commit hooks they surface findings
      # without ever blocking — advisory by construction, not by continue-on-error.
      - id: state-candidates
        name: class-shape — namespace-state (advisory)
        entry: uv run --extra devtools python -m devtools.state_candidates {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: lcom
        name: class-shape — LCOM4 cohesion (advisory)
        entry: uv run --extra devtools python -m devtools.lcom {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: data-clumps
        name: class-shape — data clumps (advisory)
        entry: uv run --extra devtools python -m devtools.data_clumps {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: magic-literals
        name: magic-literals — advisory (recurring literal / repeated key-set report)
        entry: uv run --extra devtools python -m devtools.magic_literals {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: complexity
        name: complexity — advisory (radon CC ranking; ruff C901 is the fixed gate)
        entry: uv run --extra devtools python -m devtools.complexity {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: composition-cycles
        name: composition cycles — enforced (no mutually-owning classes)
        entry: uv run --extra devtools python -m devtools.composition {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: feature-envy
        name: feature envy — enforced (a method that belongs on another class)
        entry: uv run --extra devtools python -m devtools.envy {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: use-contracts
        name: forbidden-use contracts — enforced (directional rules over the typed arrows)
        entry: uv run --extra devtools python -m devtools.contracts {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: demeter
        name: law of demeter — enforced (no calling through a field into a stranger)
        entry: uv run --extra devtools python -m devtools.demeter {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: purity
        name: property purity — enforced (a @property must not assign to self)
        entry: uv run --extra devtools python -m devtools.purity {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: test-mirror
        name: test mirror — enforced (every public method has a test_<method> that calls it and asserts)
        entry: uv run --extra devtools python -m devtools.mirror {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: unit-test-size
        name: unit test size — enforced (no external data, network, sleep, or unseeded RNG)
        entry: uv run --extra devtools python -m devtools.small {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
      - id: arrows
        name: class arrows — advisory (inherits / holds / references; the import edge decomposed by WHY)
        entry: uv run --extra devtools python -m devtools.arrows {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      - id: calls
        name: call arrows — advisory (calls reach the CONTRACT, construct reaches the CONCRETE)
        entry: uv run --extra devtools python -m devtools.calls {{ pkgs }}
        language: system
        pass_filenames: false
        always_run: true
      # Architecture graph — REGEN at PRE-PUSH (c80): rewrites docs/architecture/{graph.json,index.html} from
      # the current import graph, then keeps the committed graph.json current so the /architecture/ page it
      # feeds is fresh on the next deploy — with no manual `nox -s archmap`. Pre-push, not per-commit: commits
      # stay fast and the graph refreshes once before the push that deploys. If graph.json drifted it stages
      # the regen and BLOCKS the push — commit it and push again (the diff stays your reviewable
      # architecture-erosion signal; auto-committing in a hook can't join the in-flight push). Doc-gen, not
      # enforcement (import-linter is the directional gate; CI `archmap --check` is the backstop).
      - id: archmap
        name: architecture graph — regenerate docs/architecture/ at pre-push (commit the graph.json diff)
        # NO SHELL. This was `bash -c 'archmap ...; git diff --quiet || { git add ...; exit 1; }'` and had two
        # faults. The `;` discarded the regen's exit code, so when archmap failed the following diff saw no
        # change and the hook reported Passed — green precisely when its job did not happen (bd v3c.2). And
        # `bash` cannot reliably find `uv` on Windows, so the one hook needing a shell was the one hook that
        # did not run on the scaffold's own primary dev platform. `--regen` does both steps in the engine:
        # regenerate, then exit 1 if the committed graph.json HAD been stale. It no longer `git add`s for
        # you — the message tells you to — because staging would drag git into an engine kept git-free.
        entry: uv run --extra devtools python -m devtools.archmap {{ pkgs }} --regen
        language: system
        pass_filenames: false
        always_run: true
        stages: [pre-push]
{% if enable_ml %}      - id: shape-contracts
        name: shape-contracts — enforced (array/tensor boundaries need a jaxtyping shape; vip.4)
        entry: uv run --extra devtools python -m devtools.shape_contracts {{ pkgs }} --assert
        language: system
        pass_filenames: false
        always_run: true
{% endif %}      # Fast unit suite at the PRE-PUSH stage (not pre-commit): shift-left the CI `tests` gate so a change
      # that lints clean but breaks a test CONTRACT (e.g. a signature change a mirror test still calls the old
      # way) is caught locally before the push round-trip, not after. pre-push (pushes are rare) not pre-commit
      # (torch-import + tests every commit kills flow); tests/unit only (no integration/e2e/GPU/download — fast
      # + deterministic); NOT coverage (the floor stays a CI job). Enable once: `pre-commit install --hook-type
      # pre-push` (it is NOT installed by the default `pre-commit install`, which wires only the commit stage).
      - id: unit-tests
        name: unit tests — pre-push (fast contract check; shift-left the CI test gate)
        entry: uv run --extra dev pytest tests/unit -q
        language: system
        pass_filenames: false
        always_run: true
        stages: [pre-push]
      {# jscpd is ENFORCED in CI + nox (blocks over the jscpd.json threshold, the cardiac/mindscape
         majority) but kept OFF the commit hook — it needs Node and is slower than the static gates. A
         repo that wants it at commit time too adds a jscpd hook here. #}

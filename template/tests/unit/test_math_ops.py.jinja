import pytest

from {{ package_name }}.math_ops import MathOps


def test_mean_of_values():
    assert MathOps.mean([1.0, 2.0, 3.0]) == 2.0


def test_mean_empty_raises():
    with pytest.raises(ValueError, match="at least one value"):
        MathOps.mean([])


def test_clamp_within_interval_passthrough():
    assert MathOps.clamp(5.0, low=0.0, high=10.0) == 5.0


def test_clamp_below_low():
    assert MathOps.clamp(-1.0, low=0.0, high=10.0) == 0.0


def test_clamp_above_high():
    assert MathOps.clamp(11.0, low=0.0, high=10.0) == 10.0


def test_clamp_empty_interval_raises():
    with pytest.raises(ValueError, match="low <= high"):
        MathOps.clamp(1.0, low=10.0, high=0.0)

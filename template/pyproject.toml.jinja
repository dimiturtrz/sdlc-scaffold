[project]
name = "{{ project_name }}"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = [
{% if enable_ml %}    "numpy",
{% endif %}    "pydantic>=2",
]

[project.optional-dependencies]
dev = ["pytest", "pytest-cov"]
devtools = ["grimp", "networkx"]   # power devtools/graph.py (always shipped) — import-graph arch gate

[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[tool.setuptools.packages.find]
include = [{% for p in packages.split(",") %}"{{ p | trim }}*"{% if not loop.last %}, {% endif %}{% endfor %}]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
addopts = "--import-mode=importlib"

[tool.ruff]
line-length = 120
# >>> LOCAL-SLOT: ruff-exclude — edit freely, the template will not overwrite intent here
extend-exclude = ["docs"{% if enable_ml %}, "learning", "research", "interpretations"{% endif %}]
# <<< LOCAL-SLOT: ruff-exclude

[tool.ruff.lint]
select = [{% for c in ruff_select.split(",") %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %}]
ignore = ["RUF001", "RUF002", "RUF003"]

[tool.ruff.lint.per-file-ignores]
"__init__.py" = ["F401"]
"tests/**" = ["PLR2004", "FBT"]

[tool.vulture]
min_confidence = 60
ignore_names = ["model_config"]
ignore_decorators = ["@model_validator", "@field_validator", "@field_serializer", "@model_serializer", "@computed_field"]
# >>> LOCAL-SLOT: vulture-scan — edit freely, the template will not overwrite intent here
paths = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
exclude = []
# <<< LOCAL-SLOT: vulture-scan

[tool.coverage.run]
# >>> LOCAL-SLOT: coverage-scan — edit freely, the template will not overwrite intent here
source = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
omit = []
# <<< LOCAL-SLOT: coverage-scan

[tool.coverage.report]
show_missing = true
exclude_lines = [
    "pragma: no cover",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "^\\s*\\.\\.\\.$",
    "@(abc\\.)?abstractmethod",
]

{% if use_import_linter %}
# Directional layer gate (import-linter): forbidden-import CONTRACTS graph.py can't express — a one-way
# `core -> trainer` import is no cycle, so it passes the graph gate but must fail here. The gate is
# universal (all house repos run it); the contracts are project-local, hence the slot.
[tool.importlinter]
root_packages = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]

# >>> LOCAL-SLOT: import-contracts — your directional layer rules. Ships the kernel-independence starter
# (the FIRST package imports none of the others), the pattern all 3 house repos share. Add viewer/trainer
# or domain contracts here; edit freely — copier update won't overwrite this region.
[[tool.importlinter.contracts]]
name = "{{ packages.split(',')[0] | trim }} is an independent kernel (imports none of the other packages)"
type = "forbidden"
source_modules = ["{{ packages.split(',')[0] | trim }}"]
forbidden_modules = [{% for p in packages.split(",")[1:] %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
# <<< LOCAL-SLOT: import-contracts
{% endif %}

# Architecture fitness thresholds read by devtools/graph.py --assert.
[tool.structure]
# >>> LOCAL-SLOT: arch-thresholds — tune per repo; the template ships defaults and won't churn these,
# so a per-project override survives `copier update` without a merge conflict.
bottleneck_degree = 8    # fan-in AND fan-out both over this = god-module
file_max = 750           # god-file line ceiling — raise as real files grow
file_min = 0             # advisory line floor — 0 = OFF (no honest universal floor; raise per repo if wanted)
betweenness_max = 0.10   # advisory chokepoint threshold
test_layout = "mirror"   # every logic module needs a unit test: "mirror" = tests/unit/<pkg>/<path>/test_<name>.py
                         # (strict, one home); "flat" = test_<name>.py anywhere under tests/; "off" = no check
# <<< LOCAL-SLOT: arch-thresholds

[project]
name = "{{ project_name }}"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = [
{% if enable_ml %}    "numpy",
    "jaxtyping",   # Float[Tensor,"B C H W"] shape/dtype annotations — inert at runtime without a checker (no prod cost)
    "beartype",    # the runtime checker jaxtyping delegates to; wrap as @shapecheck in your types module (see devtools/README)
{% endif %}    "pydantic>=2",
]

[project.optional-dependencies]
dev = ["pytest", "pytest-cov"]
# The guardrail ANALYZERS are an installed package pinned by scaffold tag (not vendored source) — an engine
# update is a one-line `devtools_ref` bump on `copier update`, no source diff in your PRs. Imports as
# `devtools` (`python -m devtools.graph …`); grimp/networkx arrive transitively. ast-grep/jscpd configs are
# located from the install via `python -m devtools.config`. Pin lives in .copier-answers.yml (devtools_ref).
devtools = ["sdlc-devtools @ git+https://github.com/dimiturtrz/sdlc-scaffold.git@{{ devtools_ref }}#subdirectory=sdlc-devtools"]

[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[tool.setuptools.packages.find]
include = [{% for p in packages.split(",") %}"{{ p | trim }}*"{% if not loop.last %}, {% endif %}{% endfor %}]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
addopts = "--import-mode=importlib"

# Dependency hygiene (deptry, ENFORCED): imported-but-undeclared (DEP001) / declared-but-unused (DEP002) /
# transitive (DEP003) imports. noxfile.py imports the `nox` runner (invoked via uvx, deliberately not a
# project dep) so it's excluded from the scan.
[tool.deptry]
extend_exclude = ["noxfile.py"]

# deptry does not scan tests/ (its default exclude), so DEP002 (declared-but-unused) fires for anything
# only exercised by the test suite or by tooling. PERMANENT ignores (never imported in scanned source by
# design): the test-runner deps `pytest`/`pytest-cov`, and `sdlc-devtools` (the analyzers, invoked as a CLI
# `python -m devtools.*`). STARTERS: the runtime deps the scaffold ships for you to build on
# ({{ "numpy/jaxtyping/beartype/" if enable_ml }}pydantic) — they read as unused until you import them.
[tool.deptry.per_rule_ignores]
# >>> LOCAL-SLOT: deptry-unused — PRUNE a starter once you wire it (keep pytest/pytest-cov/sdlc-devtools)
DEP002 = ["pytest", "pytest-cov", "sdlc-devtools", {% if enable_ml %}"numpy", "jaxtyping", "beartype", {% endif %}"pydantic"]
# <<< LOCAL-SLOT: deptry-unused

[tool.ruff]
line-length = 120
# >>> LOCAL-SLOT: ruff-exclude — edit freely, the template will not overwrite intent here
extend-exclude = ["docs"{% if enable_ml %}, "learning", "research", "interpretations"{% endif %}]
# <<< LOCAL-SLOT: ruff-exclude

[tool.ruff.lint]
select = [{% for c in ruff_select.split(",") %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% if enable_ml %}ignore = [
    # jaxtyping shape strings are deliberate runtime-checked annotations that ruff's forward-ref parser
    # misreads (jaxtyping's own FAQ prescribes disabling both): F722 = a multi-token dim string
    # `Float[Tensor, "b c h w"]` (invalid forward-ref syntax); F821 = a single-axis `Float[Tensor, "n"]`
    # (a valid forward-ref to the undefined name `n`). Needed so a 1-D shape passes the now-blocking
    # shape-contracts gate (bd kqk) — the shape gate REQUIRES an annotation the lint would otherwise reject.
    "F722",
    "F821",
]{% else %}ignore = []{% endif %}

# pep8-naming (N): case convention is a UNIVERSAL rule; the allowlisted idioms are per-repo FACTS. Every
# name that carries a meaning renames — only symbols with no honest descriptive form belong here (a dodge
# makes the gate useless).
[tool.ruff.lint.pep8-naming]
# >>> LOCAL-SLOT: pep8-naming — ignore-names VOCAB (this repo's ML/physics idioms); the block is shared,
# only its contents differ. Add domain symbols (MRI T1/T2/TR/PD, canonical lib aliases…) here.
ignore-names = [{% if enable_ml %}"X*", "Y*", "B", "C", "H", "W", "F"{% endif %}]
# <<< LOCAL-SLOT: pep8-naming

[tool.ruff.lint.per-file-ignores]
# Tests get a wider carve-out: literal fixtures (PLR2004) + bool flags (FBT); mock classes mirror external
# PascalCase APIs + local math/alias scratch (N8xx); fixtures take many params (PLR0913). The SUBSTANTIVE
# gates (imports-at-top, real bugs, dead code) still apply to tests. (SLF001 is no longer enforced anywhere
# — moved to the advisory surface, bd 8ex — so it needs no tests carve-out.)
"__init__.py" = ["F401"]
"tests/**" = ["S101", "PLR2004", "FBT", "N801", "N802", "N803", "N806", "N812", "PLR0913"]
# >>> LOCAL-SLOT: per-file-ignores — repo-specific file carve-outs (e.g. a best-effort telemetry shell
# that must never raise). Add lines here; copier update won't overwrite this region.
# <<< LOCAL-SLOT: per-file-ignores

[tool.vulture]
min_confidence = 60
ignore_decorators = ["@model_validator", "@field_validator", "@field_serializer", "@model_serializer", "@computed_field"]
# ignore_names = symbols vulture must treat as USED — each IS referenced, but through a path its static
# name-match can't follow (framework dispatch, iteration, string keys, external-lib attribute). NOT a
# "don't care" list — a FACT VOCAB, per-repo, parallel to the pep8-naming slot (bd fy5). `model_config`
# is the universal pydantic base (metaclass-read); add this repo's documented FPs below.
# >>> LOCAL-SLOT: vulture-ignore-names — this repo's documented dead-code false positives
ignore_names = ["model_config"]
# <<< LOCAL-SLOT: vulture-ignore-names
# >>> LOCAL-SLOT: vulture-scan — edit freely, the template will not overwrite intent here
paths = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
exclude = []
# <<< LOCAL-SLOT: vulture-scan

[tool.coverage.run]
# >>> LOCAL-SLOT: coverage-scan — edit freely, the template will not overwrite intent here
source = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
omit = []
# <<< LOCAL-SLOT: coverage-scan

[tool.coverage.report]
show_missing = true
exclude_lines = [
    "pragma: no cover",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "^\\s*\\.\\.\\.$",
    "@(abc\\.)?abstractmethod",
]

{% if use_import_linter %}
# Directional layer gate (import-linter): forbidden-import CONTRACTS graph.py can't express — a one-way
# `core -> trainer` import is no cycle, so it passes the graph gate but must fail here. The gate is
# universal (all house repos run it); the SCOPE + contracts are project-local, hence the slot.
# >>> LOCAL-SLOT: import-contracts — layering scope + your directional rules. `root_packages` is the set
# import-linter analyses (defaults to `packages`; widen it if a scope-only package such as a viewer carries
# layer rules but isn't in the arch set). Ships the kernel-independence starter (the FIRST package imports
# none of the others), the pattern all 3 house repos share. Add viewer/trainer or domain contracts below;
# edit freely — copier update won't overwrite this region.
[tool.importlinter]
root_packages = [{% for p in packages.split(",") %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]

[[tool.importlinter.contracts]]
name = "{{ packages.split(',')[0] | trim }} is an independent kernel (imports none of the other packages)"
type = "forbidden"
source_modules = ["{{ packages.split(',')[0] | trim }}"]
forbidden_modules = [{% for p in packages.split(",")[1:] %}"{{ p | trim }}"{% if not loop.last %}, {% endif %}{% endfor %}]
# <<< LOCAL-SLOT: import-contracts
{% endif %}

# Architecture fitness thresholds read by devtools/graph.py --assert.
[tool.structure]
# >>> LOCAL-SLOT: arch-thresholds — tune per repo; the template ships defaults and won't churn these,
# so a per-project override survives `copier update` without a merge conflict.
bottleneck_degree = 8    # fan-in AND fan-out both over this = god-module
file_max = 750           # god-file line ceiling — raise as real files grow
file_min = 0             # advisory line floor — 0 = OFF (no honest universal floor; raise per repo if wanted)
betweenness_max = 0.10   # advisory chokepoint threshold
main_sequence_max = 0.0  # advisory Martin main-sequence distance |A+I-1| ceiling — 0 = OFF (a concrete
                         # stable leaf legitimately sits at D≈1, so no honest universal floor; raise per repo)
test_layout = "mirror"   # every logic module needs a unit test: "mirror" = tests/unit/<pkg>/<path>/test_<name>.py
                         # (strict, one home); "flat" = test_<name>.py anywhere under tests/; "off" = no check
# <<< LOCAL-SLOT: arch-thresholds

# magic-literals ENFORCED ratchet (devtools/magic_literals.py) — the recurring-string / repeated-key-set
# floor is frozen as a ceiling; a NEW magic literal pushes the count over and fails the merge (migrate it
# to a StrEnum/constant, or raise the ceiling in the same commit with a reason). The MECHANISM is a base
# gate (all repos run it enforced); the NUMBERS are a per-repo FACT (each repo's legitimate non-enum-able
# floor differs — column names, framework vocab, path segments). A fresh repo ships 0/0 and ratchets up.
[tool.magic_literals]
# >>> LOCAL-SLOT: magic-ceilings — this repo's frozen literal floor (raise only with a documented reason)
max_strings = 0
max_key_sets = 0
# <<< LOCAL-SLOT: magic-ceilings

# Cyclomatic-complexity gate (devtools/complexity.py, radon CC). ADVISORY by default — the report prints the
# ranking + your current max, but nothing blocks. ruff C901/PLR09xx already own the FIXED CC>10 floor; this
# owns the RATCHET below it. Set max_complexity to your current radon max (from the report) to freeze it —
# then a more-complex function fails the merge, catching a regression long before ruff's 10.
[tool.complexity]
# >>> LOCAL-SLOT: complexity-ceiling — uncomment + set to your current max radon CC to ratchet (e.g. 8);
# absent = advisory (report only).
# max_complexity = 8
# <<< LOCAL-SLOT: complexity-ceiling
{% if enable_ml %}
# Shape-contract gate (devtools/shape_contracts.py) — a public array/tensor boundary must carry a
# jaxtyping shape, not a bare `np.ndarray`/`Tensor`. The universal `ndarray`/`Tensor` are builtin; a
# repo's own array ALIASES (its core.types names that also mean "an array") are the FACT that varies.
[tool.shape_contracts]
# >>> LOCAL-SLOT: shape-aliases — this repo's array-alias type names (e.g. Volume, Mask, Image, Batch)
array_aliases = []
# <<< LOCAL-SLOT: shape-aliases
{% endif %}

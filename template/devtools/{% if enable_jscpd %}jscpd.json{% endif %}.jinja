{
  "//": "Duplication detector — the DRY axis coupling tools can't see. A fresh project is 0% dup = REGRESSION GUARD. threshold = max % dup before nonzero exit. PATHS are passed on the CLI (jscpd resolves a config `path` relative to the config file, which breaks when the config lives under devtools/) — run: `jscpd <src dirs...> --config devtools/jscpd.json`. Advisory in CI until the Node step proves stable, then graduate to blocking.",
  "threshold": 1,
  "minTokens": 50,
  "gitignore": true,
  "ignore": ["**/node_modules/**", "**/dist/**", "**/__pycache__/**", "**/.staging/**"],
  "reporters": ["console"],
  "absolute": false
}
